generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String?
  image    String?

  documents      Document[]      @relation("OwnerDocuments")
  collaborations Collaboration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          String  @id @default(cuid())
  title       String
  description String?
  content     Json

  ownerId String
  owner   User   @relation("OwnerDocuments", fields: [ownerId], references: [id])

  visibility Visibility @default(PRIVATE)

  status DocumentStatus @default(ACTIVE)

  icon       String?
  coverImage String?

  wordCount      Int @default(0)
  characterCount Int @default(0)

  currentVersion Int @default(1)

  lastEditedBy String?
  lastEditedAt DateTime?

  isFavorite Boolean @default(false)
  isArchived Boolean @default(false)
  isDeleted  Boolean @default(false)

  collaborators Collaboration[]
  versions      DocumentVersion[]
  comments      Comment[]
  syncLogs      SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model Collaboration {
  id String @id @default(cuid())

  userId     String
  documentId String

  role Role

  invitedBy String?

  accepted Boolean @default(true)

  lastSeen DateTime?

  user User @relation(fields: [userId], references: [id])

  document Document @relation(fields: [documentId], references: [id])

  @@unique([userId, documentId])
}

model DocumentVersion {
  id String @id @default(cuid())

  documentId String

  version Int

  title String

  content Json

  createdBy String

  summary String?

  createdAt DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])
}

model Comment {
  id String @id @default(cuid())

  documentId String

  userId String

  message String

  resolved Boolean @default(false)

  createdAt DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])
}

model SyncLog {
  id String @id @default(cuid())

  documentId String

  operation Operation

  payload Json

  status SyncStatus

  retryCount Int @default(0)

  createdAt DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])
}

model Activity {
  id String @id @default(cuid())

  documentId String

  userId String

  action ActivityType

  metadata Json?

  createdAt DateTime @default(now())
}

enum Visibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum SyncStatus {
  PENDING
  SYNCING
  COMPLETED
  FAILED
}

enum Operation {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

enum ActivityType {
  CREATED
  UPDATED
  COMMENTED
  SHARED
  RESTORED
  DELETED
}
